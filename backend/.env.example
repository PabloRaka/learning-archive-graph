# FastAPI Settings
PROJECT_NAME="Daily Learning Knowledge Graph API"
API_V1_STR="/api"

# Database connection
# For local development, use SQLite: sqlite:///./knowledge_graph.db
# For PostgreSQL integration, set: postgresql://user:password@host:port/dbname
DATABASE_URL="sqlite:///./knowledge_graph.db"

# CORS configurations (comma-separated list of allowed origins)
BACKEND_CORS_ORIGINS="http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000"
